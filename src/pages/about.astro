---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import "../styles/global.css";
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&display=swap" rel="stylesheet">
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<title>Contact</title>

</head>

<body>		
	<Header />
	<div class = "about">
		<div class="about-textbox">
			<h3>Hi, I'm Michael.</h3>
			<p>Learning Designer, Educator, and Innovator. <br>
			I design programs that expand access to higher education.</p>
		</div>
		<div class="about-profile">
			<img src="../../profile-podium-small.jpg" alt="Profile Picture" class="profile-pic">
		</div>
	</div>

	<!-- ABOUT ME SECTION -->
<div class="parallax">
	<div class="container-title">
			<h2>About Me</h2>
			<p><em>My Educational Journey</em></p>
	</div>
	
	<div class = "container-home">
		<div class="container-text">
			<h3>Born and raised in Las Vegas, Nevada, I grew up in one of the <strong>lowest performing school districts</strong> in the US.</h3>
			<!--  
			<p><em>I saw firsthand how the education system sorts students into separate tracks based on their backgrounds and early achievements.</em></p>
			-->
		</div>
	</div>
	
	<div class = "container-home">
		<div class="container-text">
			<h3>Like many high-achieving students, I set my sights on an <strong>elite college.</strong> </h3>
		</div>
	</div>

	<div class = "container-home">
		<div class="container-text">
			<h3>Now in a Master's in Learning Design and Technology, I design programs that <strong>expand access</strong> to higher education.</h3>
		</div>
	</div>

</div>
	
</div>

	<div class = "container-home about-me-container">
		<div class="container-text">
			<h3>Born and raised in Las Vegas, Nevada, I grew up in one of the <strong>lowest performing school districts</strong> in the US.</h3>
			<!--  
			<p><em>I saw firsthand how the education system sorts students into separate tracks based on their backgrounds and early achievements.</em></p>
			-->
		</div>
		<!-- 
		<span class="container-img clark"></span> 
		-->
		<!-- 
		<span class="container-img healy"></span>
		-->
			
		<div class="container-text">
			<h3>Like many high-achieving students, I set my sights on an <strong>elite college.</strong> </h3>
			<!--  
			<p><em>I went to Georgetown University, where I built an appreciation for values-based education that cares for the whole person. All the while, I struggled with the amount of wealth, privilege, and homogeneity that dominated the school.</em></p>
			-->
			
		</div>
		<div class="container-text">
			<h3>Now in a Master's in Learning Design and Technology, I design programs that <strong>expand access</strong> to higher education.</h3>
			<!--  
			<p><em>Meanwhile, I work at the Office of Advancement, which raises funds for scholarships.</em></p>
			-->
			
		</div>
