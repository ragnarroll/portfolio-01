---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import "../styles/global.css";
import "../styles/home.css";
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Hedvig+Letters+Serif:opsz@12..24&display=swap" rel="stylesheet">
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<title>Michael Pasimio Portfolio</title>

</head>

<body>		
	<Header />

	<div class = "hero">
		<div class="hero-textbox">
			<h1>Transforming education,<br>building <em class="serif">community</em></h1>
			<div class="orange-line"></div>
			<h3>Michael Vincent Pasimio</h3>
			<h4><em>Learning Designer, Educator, Innovator<br>
			Based in Washington, DC</em></h4>
		</div>
		
	</div>

	



<section>
	<div class="two-column-layout">
		<div class="two-column-layout__title">
			<h4 class="serif italics">Mission</h4>
			<h2>My Goal</h2>
		</div>
		<div class="two-column-layout__content with-line">
			<h4>Design <u>transformative education initiatives</u> that <strong>promote success</strong> for <em>all</em> students and <strong>strengthen communities.</strong></h4>
	</div>
</section>

<section class="light-gradient-background">
	<div class="section-title">
		<h4 class="serif italics">Values</h4>
		<h2>My Design Principles</h2>
	</div>
		
	</div>
	<div class="design-principles">
		<div class="principle">
			<div class="principle-header">
				<img src="../../expand.png" class="expand-icon" style="width: 30px; height: 30px;" alt="Expand Icon">
				<img src="../../collapse.png" class="collapse-icon" style="width: 30px; height: 30px;" alt="Collapse Icon">
				<h3>radical inclusivity</h3>
			</div>
			<div class="principle-text">
				<p>ai text: Designing with empathy and a deep understanding of human needs, behaviors, and emotions.</p>
			</div>
		</div>
		<div class="principle">
			<div class="principle-header">
				<img src="../../expand.png" class="expand-icon" style="width: 30px; height: 30px;" alt="Expand Icon">
				<img src="../../collapse.png" class="collapse-icon" style="width: 30px; height: 30px;" alt="Collapse Icon">
				<h3>systems-thinking</h3>
			</div>
			<div class="principle-text">
				<p>ai text: Prioritizing the well-being and success of communities, fostering collaboration and collective growth.</p>
			</div>
		</div>
		<div class="principle">
			<div class="principle-header">
				<img src="../../expand.png" class="expand-icon" style="width: 30px; height: 30px;" alt="Expand Icon">
				<img src="../../collapse.png" class="collapse-icon" style="width: 30px; height: 30px;" alt="Collapse Icon">
				<h3>human-centered technology</h3>
			</div>
			<div class="principle-text">
				<p>ai text: Striving to create inclusive and accessible educational experiences that empower all learners.</p>
			</div>
		</div>
	</div>
</section>

<section class="gradient-background">
	<div class="section-title">
		<h4 class="serif italics">Process</h4>
		<h2>Selected Works</h2>
	</div>
	
	<div class="two-column-layout">
		<div class="two-column-layout__title">
			<a href="/projects/the-tennis-journey">
				<div class="selected-works-img project-1 smaller">
				</div>
			</a>
		</div>
		<div class="two-column-layout__content">
			<h3><u>A College for Equality</u></h3>
			<p>A case study of Livingston College at Rutgers University, an experimental college in the 70s designed for affirmative action, engaged scholarship, and social change.</p>	
		</div>
		<div class="two-column-layout__title">
			<a href="/projects/the-tennis-journey">
				<div class="selected-works-img project-2 smaller">
				</div>
			</a>
		</div>
		<div class="two-column-layout__content">
			<h3><u>Lifelong Learning through Sports</u></h3>
			<p>A workshop series with high school athletes, college athletes, and parents on building a long term relationship with movement and preventing burnout.</p>
		</div>
		<div class="two-column-layout__title">
			<a href="/projects/the-tennis-journey">
				<div class="selected-works-img project-3 smaller"></div>
			</a>
		</div>
		<div class="two-column-layout__content">
			<h3><u>The Pivotal Network</u></h3>
			<p>A co-designed network of teachers at Title I schools, designed to promote student success and college attainment through professional development.</p>
		</div>
	</div>
</section>

	<Footer />

	<script src="../scripts/viewport-animations.js"></script>
	<script src="../scripts/collapsible-principles.js"></script>
</body>
</html>
